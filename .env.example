# 复制此文件为 .env 并填入真实值（.env 不会被提交到 git）
# 所有配置只来自环境变量；未设置的项使用内置默认值。

# ===== LLM Provider =====
# provider 类型：anthropic（默认）/ openai / ollama
PROVIDER_TYPE=anthropic

# 凭证（anthropic / openai 需要；ollama 为本地服务无需鉴权）：
# - anthropic：API Key 走 x-api-key，AUTH_TOKEN 走 Bearer，二选一（同时存在时优先 AUTH_TOKEN）
# - openai：API Key 与 AUTH_TOKEN 等价，都以 Bearer 发送，二选一即可
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
ANTHROPIC_LLM_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxx

# 自定义 API base url（可选，用于代理/兼容网关；ollama 用它指向服务，缺省 http://localhost:11434）
# ANTHROPIC_BASE_URL=https://api.anthropic.com

# 模型名称（可选，默认 claude-sonnet-4-6 —— 该默认值仅适用于 anthropic）。
# 切到 openai / ollama 时务必显式设置对应模型名，否则会用错模型导致请求失败：
# LLM_MODEL=claude-sonnet-4-6        # anthropic
# LLM_MODEL=gpt-4o-mini             # openai（或兼容网关上的模型名）
# LLM_MODEL=llama3.1                # ollama（需所选模型支持工具调用）

# ===== 工作目录 =====
# Agent 可操作的目录（可选，默认当前目录）。所有文件/命令操作被限制在此目录内。
# WORKDIR=./examples

# ===== 运行参数 =====
# 命令执行超时（毫秒，默认 30000）
# COMMAND_TIMEOUT_MS=30000
# read_file 默认最多读取行数（默认 2000）
# READ_FILE_MAX_LINES=2000
# run_command 输出字节预算（默认 30720=30KB）
# COMMAND_OUTPUT_MAX_BYTES=30720
# 单轮提交内 agent 执行次数的绝对上限（防御性硬兜底，默认 100）
# MAX_ITERATIONS=100
# 死循环检测阈值：连续重复同一动作达到该次数即停止（默认 4）
# MAX_REPEATED_ACTIONS=4

# ===== 沙箱隔离（US-016）=====
# 后端选择：auto（默认，按平台自动选最强；缺少原生机制时自动降级为 none）
#          / none（显式关闭隔离）/ seatbelt / bwrap / jobobject
# SANDBOX_BACKEND=auto
# 是否允许命令访问网络（默认 true；npm install 等通常需要联网，设 false 可切断）
# SANDBOX_ALLOW_NETWORK=true
# 默认可写白名单（cwd + tmp + 包管理器缓存）之外额外允许写入的绝对路径，逗号分隔
# SANDBOX_WRITABLE_PATHS=/abs/path/a,/abs/path/b
# 默认环境变量白名单之外额外透传给被执行命令的变量名，逗号分隔
# SANDBOX_ENV_PASSTHROUGH=FOO,BAR
# 资源上限（缺省即不限制）：最大子进程数 / 最大内存字节 / 最大 CPU 秒
# SANDBOX_MAX_PROCESSES=64
# SANDBOX_MAX_MEMORY_BYTES=1073741824
# SANDBOX_CPU_TIME_SECONDS=60

# ===== 降低 token 消耗（US-015，可选）=====
# 启用 Anthropic prompt caching：缓存 tools+system 稳定前缀省输入 token（需端点支持 cache_control）
# PROMPT_CACHING=false
# 历史工具结果重发字节上限：超过则头尾截断，省多轮输入 token（0=不压缩，默认 8192）
# HISTORY_TOOL_RESULT_MAX_BYTES=8192
# 对话历史自动压缩阈值（US-024）：history 估算字节超过该值时用 LLM 摘要旧历史（0=关闭，默认 61440=60KB）
# HISTORY_COMPACTION_MAX_BYTES=61440

# ===== Langfuse 监控（全部可选；不配置则自动关闭）=====
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
