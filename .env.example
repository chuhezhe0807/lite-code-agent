# 复制此文件为 .env 并填入真实值（.env 不会被提交到 git）

# ===== LLM Provider =====
# provider 类型：anthropic（默认）/ openai / ollama
PROVIDER_TYPE=anthropic

# 凭证二选一（同时存在时优先用 AUTH_TOKEN 的 Bearer 方式）：
# 方式一：API Key —— 以 x-api-key 头发送（官方 Anthropic 用这个）
# ANTHROPIC_API_KEY=sk-ant-xxxxxxxxxxxxxxxx
# 方式二：Auth Token —— 以 Authorization: Bearer 头发送（LiteLLM 等代理/网关、Claude Code 常用）
ANTHROPIC_LLM_AUTH_TOKEN=sk-xxxxxxxxxxxxxxxx

# 自定义 API base url（可选，用于代理或兼容网关）
# ANTHROPIC_BASE_URL=https://api.anthropic.com
# 模型名称（可选，默认 claude-sonnet-4-6）
# LLM_MODEL=claude-sonnet-4-6

# ===== 工作目录 =====
# Agent 可操作的目录（可选，默认当前目录）。所有文件/命令操作被限制在此目录内。
# WORKDIR=./examples

# ===== Langfuse 监控（全部可选；不配置则自动关闭）=====
# LANGFUSE_PUBLIC_KEY=pk-lf-xxxxxxxx
# LANGFUSE_SECRET_KEY=sk-lf-xxxxxxxx
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
